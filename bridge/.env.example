# --- Supabase ---
# Project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=
# Service-role key (Settings > API > service_role). It bypasses RLS, so the
# bridge can read every room/slot and insert activity. Keep it secret — it never
# leaves the Pi.
SUPABASE_SERVICE_ROLE_KEY=

# --- ntfy ---
# Base URL the BRIDGE uses to reach ntfy:
#   - Public instance:            https://ntfy.sh
#   - Self-hosted in this compose: http://ntfy:80   (internal service name)
# Note: your PHONE subscribes from outside using the Pi's LAN address instead,
# e.g. http://<your-pi-ip>:8080
# For users in different homes, keep https://ntfy.sh — the self-hosted LAN
# address only reaches phones connected to your home WiFi.
NTFY_BASE_URL=https://ntfy.sh
# Fallback topic used for rooms that don't define their own `ntfy_topic`.
# Pick something random and hard to guess (anyone who knows the topic can read it).
NTFY_DEFAULT_TOPIC=aptracker-changeme-8f3a9c

# --- Behaviour (optional) ---
# How often (seconds) the bridge re-reads rooms/slots from Supabase.
SYNC_INTERVAL_SECONDS=60
# Max backoff between reconnect attempts (seconds).
RECONNECT_MAX_BACKOFF_SECONDS=60
# Set to true only if your Archipelago server uses a self-signed TLS cert.
AP_TLS_INSECURE=false
# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# --- FCM (optional: native push for Android) ---
# Path INSIDE the container to the Firebase service-account JSON (mounted
# read-only via docker-compose from bridge/service-account.json). Leave unset to
# disable FCM and use ntfy only. iOS always uses ntfy.
FCM_SERVICE_ACCOUNT_FILE=/app/service-account.json
